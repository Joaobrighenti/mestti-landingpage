{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "redirects": [
    { "source": "/sensores/empresa", "destination": "/empresa/", "permanent": true },
    { "source": "/sensores/empresa/", "destination": "/empresa/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/contato", "destination": "/contato/index.html" },
    { "source": "/contato/", "destination": "/contato/index.html" },
    { "source": "/empresa", "destination": "/empresa/index.html" },
    { "source": "/empresa/", "destination": "/empresa/index.html" },
    { "source": "/atuacao", "destination": "/atuacao/index.html" },
    { "source": "/atuacao/", "destination": "/atuacao/index.html" }
  ]
}
